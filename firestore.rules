rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /messages/{messageId} {
      // Anyone can read messages
      allow read: if true;

      // Anyone can create a message with valid fields
      allow create: if request.resource.data.keys().hasAll(['room', 'ts', 'name'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.room is string
        && request.resource.data.room.size() > 0;

      // No updates allowed
      allow update: if false;

      // No deletes allowed from client
      allow delete: if false;
    }
  }
}
